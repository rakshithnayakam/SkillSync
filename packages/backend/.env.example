# ── Server ────────────────────────────────────────────────
PORT=8000

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skillsync?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your-super-secret-access-key-change-this
ACCESS_TOKEN_EXPIRY=1d
ACCESS_TOKEN_EXPIRY_JWT=1d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-change-this
REFRESH_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY_JWT=7d

# ── CORS ──────────────────────────────────────────────────
# Local dev:
CORS_ORIGIN=http://localhost:5173
# Production (update after deploying frontend):
# CORS_ORIGIN=https://your-app.vercel.app

# ── Email (nodemailer) ────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
